# === Supabase ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Kajabi ===
# En production, ces valeurs vivent dans Supabase Vault (vault.secrets).
# Ces variables ne servent qu'au dev local et aux scripts one-shot.
KAJABI_CLIENT_ID=
KAJABI_CLIENT_SECRET=
KAJABI_SITE_ID=
KAJABI_API_BASE_URL=https://api.kajabi.com

# === Webhook signing (à configurer plus tard) ===
KAJABI_WEBHOOK_SECRET=
